        {
            "parameters": {
                "name": "compare_companies",
                "description": "So sánh hai công ty về các chỉ số tài chính: Profitability (lợi nhuận), Liquidity (thanh khoản), và Efficiency (hiệu quả). Sử dụng tool này khi người dùng muốn so sánh, phân tích hoặc đánh giá hai công ty.",
                "method": "POST",
                "url": "http://localhost:8001/api/v1/compare/",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"ticker1\": \"{ticker1}\",\n  \"ticker2\": \"{ticker2}\",\n  \"quarter\": \"{quarter}\"\n}",
                "placeholderDefinitions": {
                    "values": [
                        {
                            "name": "ticker1",
