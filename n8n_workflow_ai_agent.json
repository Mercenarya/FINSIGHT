                            "type": "string"
                        },
                        {
                            "name": "ticker2",
                            "description": "Mã cổ phiếu công ty thứ hai (ví dụ: VIC, VNM, FPT)",
                            "type": "string"
                        },
                        {
                            "name": "quarter",
                            "description": "Quý cần phân tích. Mặc định là Third_quarter. Các giá trị: First_quarter, Second_quarter, Third_quarter, Fourth_quarter",
                            "type": "string"
                        }
                    ]
                }
            },
            "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
            "typeVersion": 1.1,
            "position": [
