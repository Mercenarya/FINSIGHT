        {
            "parameters": {
                "options": {
                    "systemMessage": "Bạn là trợ lý phân tích tài chính chuyên nghiệp. Nhiệm vụ của bạn là:\n\n1. Hiểu yêu cầu của người dùng về việc so sánh các công ty\n2. Trích xuất mã cổ phiếu (ticker) từ câu hỏi\n3. Gọi API phân tích tài chính để lấy dữ liệu\n4. Giải thích kết quả một cách dễ hiểu\n\nCác chỉ số bạn có thể phân tích:\n- Profitability (Khả năng sinh lời): Gross Margin, Net Margin, ROA, ROE\n- Liquidity (Thanh khoản): Current Ratio, Quick Ratio, Cash Ratio\n- Efficiency (Hiệu quả): Asset Turnover, Inventory Turnover, Receivables Turnover\n\nKhi trả lời, hãy:\n- Giải thích ý nghĩa của từng chỉ số\n- So sánh và đưa ra nhận xét\n- Đề xuất công ty nào tốt hơn dựa trên từng khía cạnh"
                }
            },
            "type": "@n8n/n8n-nodes-langchain.agent",
            "typeVersion": 3,
            "position": [
                1008,
                -144
            ],
            "id": "ai-agent-node",
            "name": "AI Agent"
        },
        {
            "parameters": {
                "options": {
                    "modelName": "gemini-1.5-flash"
                }
            },
            "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
            "typeVersion": 1,
            "position": [
                880,
